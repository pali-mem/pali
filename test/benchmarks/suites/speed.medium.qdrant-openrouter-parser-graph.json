{
  "name": "speed-medium-qdrant-openrouter-parser-graph",
  "description": "Medium-scale qdrant + openrouter lane with openrouter parser and graph singleton invalidation enabled.",
  "out_root": "test/benchmarks/results/suites",
  "fail_fast": false,
  "common": {
    "benchmark": {
      "fixture": "testdata/benchmarks/fixtures/locomo_medium500.fixture.json",
      "eval_set": "testdata/benchmarks/evals/locomo_medium500.eval.json",
      "top_k": 5,
      "search_ops": 600
    },
    "retrieval_quality": {
      "fixture": "testdata/benchmarks/fixtures/locomo_medium500.fixture.json",
      "eval_set": "testdata/benchmarks/evals/locomo_medium500.eval.json",
      "top_k": 5,
      "max_queries": 0
    }
  },
  "scoring_defaults": {
    "latency_slo_ms": {
      "search": {
        "p50": 90,
        "p95": 140,
        "p99": 220
      },
      "store": {
        "p95": 200
      }
    },
    "throughput_targets_ops_sec": {
      "store": 10,
      "search": 6
    },
    "weights": {
      "latency": 0.7,
      "throughput": 0.3
    }
  },
  "scenarios": [
    {
      "id": "qdrant_openrouter_parser_graph_speed_medium",
      "runner": "benchmark",
      "enabled": true,
      "args": {
        "backend": "qdrant",
        "embedding_provider": "openrouter",
        "config_profile": "test/config/providers/openrouter-parser-graph.yaml",
        "qdrant_url": "http://127.0.0.1:6333",
        "qdrant_collection": "pali_memories_medium_openrouter_parser_graph",
        "qdrant_isolate_run": "true"
      }
    },
    {
      "id": "qdrant_openrouter_parser_graph_retrieval_medium",
      "runner": "retrieval_quality",
      "enabled": true,
      "args": {
        "backend": "qdrant",
        "embedding_provider": "openrouter",
        "config_profile": "test/config/providers/openrouter-parser-graph.yaml",
        "qdrant_url": "http://127.0.0.1:6333",
        "qdrant_collection": "pali_memories_medium_openrouter_parser_graph",
        "qdrant_isolate_run": "true"
      }
    }
  ]
}
