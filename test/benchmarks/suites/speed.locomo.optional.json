{
  "name": "speed-locomo-optional",
  "description": "Optional LoCoMo lane for paper-style retrieval + QA metrics; disabled by default because it is expensive.",
  "out_root": "test/benchmarks/results/suites",
  "fail_fast": false,
  "common": {
    "locomo_qa": {
      "fixture": "research/data/locomo10.paperlite.fixture.json",
      "eval_set": "research/data/locomo10.paperlite.eval.json",
      "vector_backend": "qdrant",
      "embedding_provider": "ollama",
      "embedding_model": "all-minilm",
      "answer_mode": "extractive",
      "retrieval_kind_routing": true,
      "retrieval_answer_type_routing": true,
      "retrieval_early_rank_rerank": true,
      "retrieval_temporal_resolver": true,
      "top_k": 10,
      "max_queries": 25,
      "host": "127.0.0.1",
      "port": 18092,
      "qdrant_url": "http://127.0.0.1:6333",
      "qdrant_collection": "pali_memories_locomo_suite",
      "qdrant_timeout_ms": 2000
    }
  },
  "scenarios": [
    {
      "id": "locomo_qdrant_ollama_extract",
      "runner": "locomo_qa",
      "enabled": false
    }
  ]
}
