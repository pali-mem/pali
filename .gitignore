#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Macos files
.DS_Store

# Test binary, built with `go test -c`
*.test

# Code coverage 1rofiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Build and local runtime artifacts
bin/
.cache/
site/

# Local config
pali.yaml

# Downloaded ONNX model artifacts
models/all-MiniLM-L6-v2/model.onnx
models/all-MiniLM-L6-v2/tokenizer.json

# env file
.env

# Python virtual environment
.venv/

# Editor/IDE
# .idea/
# .vscode/


#database
*.db
*.db-shm
*.db-wal

# Benchmark results and generated fixture outputs
test/benchmarks/results/
test/benchmarks/generated/

# Research
/research/*

# Built binaries (root-level)
genfix
/pali

.vscode/


# Test files

test/fixtures/
